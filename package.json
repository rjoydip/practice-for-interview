{
  "workspaces": {
    "packages": [
      "js_ts/*",
      "react/*"
    ],
    "catalog": {
      "@typescript/native-preview": "^7.0.0-dev.20260204.1"
    }
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "oxfmt .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "type_check": "turbo typecheck"
  },
  "devDependencies": {
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --ignore-scripts --offline && bun run lint && bun run type_check"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.0"
  },
  "packageManager": "bun@1.3.8"
}

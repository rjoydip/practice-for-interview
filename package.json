{
	"packageManager": "bun@1.3.8",
	"engines": {
		"node": ">=22.0",
		"bun": ">=1.3.5"
	},
	"scripts": {
		"prepare": "simple-git-hooks",
		"lint": "biome lint --write",
		"format": "biome format --write",
		"type_check": "turbo typecheck"
	},
	"simple-git-hooks": {
		"pre-commit": "bun install --ignore-scripts --offline && bunx biome ci . && bun run type_check"
	},
	"workspaces": {
		"catalog": {
			"@typescript/native-preview": "^7.0.0-dev.20260204.1"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.14",
		"simple-git-hooks": "^2.13.1",
		"turbo": "^2.8.3"
	}
}

{
  "name": "practice-for-interview",
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "oxlint . && oxfmt --check .",
    "fmt": "oxfmt .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "actions:up": "actions-up up",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "actions-up": "^1.10.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260212.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.46.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --ignore-scripts --offline && bun run lint && bun run typecheck && bun run actions:up"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.0"
  },
  "packageManager": "bun@1.3.8"
}

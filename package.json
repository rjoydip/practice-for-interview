{
  "name": "practice-for-interview",
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "actions-up": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.61.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "bun install --ignore-scripts --offline && bun run lint && bun run typecheck && bunx actions-up"
  },
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=22.0"
  },
  "packageManager": "bun@1.3.8"
}
